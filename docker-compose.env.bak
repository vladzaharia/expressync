# Database Configuration
DATABASE_URL=postgresql://expressync:hN8O9MBYDJ88vuCLEBybiidgPLYUul1gBwd0p6xkmA2sue9M0kZA6fkJ1CHJV@postgres:5432/expressync

# StEvE OCPP Management System
# Base URL for StEvE (e.g., http://localhost:8080/steve)
# Dashboard links use the base URL, API calls use base URL + /api
STEVE_BASE_URL=https://ocpp.polaris.express/steve/
# REST API uses HTTP Basic auth (SteVe 3.8+). Username = SteVe's auth.user; password = webapi.value.
STEVE_API_USERNAME=vlad
STEVE_API_KEY=2ec7JmU9l8cY41qQPe7yRKWwtuaB5YFNq5nDnx8FunDNrvK8gY

# Lago Billing Platform
# API base URL (final URL will be this + /api/v1)
LAGO_API_URL=http://lago-api:3000
LAGO_API_KEY=66848491-a7e4-41c8-bfe4-221a9ab88acf
# Dashboard URL for external links (separate from API)
LAGO_DASHBOARD_URL=https://billing.polaris.express

# Lago Billable Metric Code
# This is the code of the billable metric in Lago for kWh consumption
LAGO_METRIC_CODE=kwh

# Sync Configuration
SYNC_CRON_SCHEDULE="*/15 * * * *"
SYNC_ON_STARTUP=false
# 7-day lookback protects against worker outages / certificate renewals /
# StEvE downtime — default 1440 (24h) silently drops older completed
# transactions if the worker lags. Raise if you see missed bills.
SYNC_LOOKBACK_MINUTES=10080

# Application Configuration
PORT=8000
DENO_ENV=production
DEBUG_LEVEL=VERBOSE

# Docker Configuration
DOCKER_SOCKET_PATH=/var/run/docker.sock
STEVE_CONTAINER_NAME=ocpp-app-1

# BetterAuth Configuration
AUTH_SECRET=5pYjc6CIBzdWllCc1tMpurVfAI2YMbduzEQBzGmB3gXIMrBFn9BKLfvEteM5G0
AUTH_URL=https://manage.polaris.express
