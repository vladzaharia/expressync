# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ocpp_billing
POSTGRES_DB=ocpp_billing
POSTGRES_PASSWORD=ocpp_password
POSTGRES_USER=ocpp_user

# StEvE OCPP Management System
# Base URL for StEvE (e.g., http://localhost:8080/steve)
# Dashboard links use the base URL, API calls use base URL + /api
STEVE_BASE_URL=http://localhost:8080/steve
# REST API uses HTTP Basic auth (since SteVe 3.8).
# STEVE_API_USERNAME matches SteVe's auth.user; STEVE_API_KEY matches webapi.value.
STEVE_API_USERNAME=admin
STEVE_API_KEY=your_steve_api_key_here

# Lago Billing Platform
# API base URL (final URL will be this + /api/v1)
LAGO_API_URL=https://api.getlago.com
LAGO_API_KEY=your_lago_api_key_here
# Dashboard URL for external links (separate from API)
LAGO_DASHBOARD_URL=https://app.getlago.com

# Lago Billable Metric Code
# This is the code of the billable metric in Lago for kWh consumption
LAGO_METRIC_CODE=ev_charging_kwh

# Sync Configuration
# Adaptive cadence (Phase C) is the default: Active 15m / Idle 1h / Dormant 1w.
# SYNC_CRON_SCHEDULE is now an OPTIONAL escape-hatch override. If set to a
# non-empty cron pattern, the scheduler will use that pattern for all tiers.
# Leave commented out to let the scheduler adapt.
# SYNC_CRON_SCHEDULE=*/15 * * * *

# Application Configuration
PORT=8000
DENO_ENV=development

# Debug/Logging Configuration
# Log level for debugging production issues
# Options: ERROR (default), WARN, INFO, DEBUG
# - ERROR: Only errors (minimal logging, production default)
# - WARN: Warnings and errors
# - INFO: Info, warnings, and errors (recommended for production debugging)
# - DEBUG: All logs including detailed debug information (verbose, use for development/troubleshooting)
DEBUG_LEVEL=ERROR

# Sync Worker Configuration
# SYNC_CRON_SCHEDULE: optional override for the adaptive scheduler (Phase C).
# If set to a non-empty cron pattern, the worker uses that pattern for ALL
# tiers, disabling adaptive behavior. Examples:
#   */15 * * * * = every 15 minutes
#   0 */1 * * *  = every hour
#   0 0 * * *    = daily at midnight
# SYNC_CRON_SCHEDULE=
# Run sync immediately on worker startup (useful for testing)
SYNC_ON_STARTUP=false
# How far back to look at completed StEvE transactions on each sync tick.
# Default 1440 (24h). 7 days (10080) is safer if the worker can lag.
SYNC_LOOKBACK_MINUTES=10080

# Adaptive cadence tunables (Phase C)
# Days of no activity before demoting from Idle to Dormant (default 30)
SYNC_DORMANT_THRESHOLD_DAYS=30
# Consecutive idle evaluations required to demote a tier (default 2)
SYNC_IDLE_HYSTERESIS_TICKS=2

# Docker Configuration (for tag detection log streaming)
# Path to Docker socket for streaming StEvE container logs
DOCKER_SOCKET_PATH=/var/run/docker.sock
# Name of the StEvE Docker container to stream logs from
STEVE_CONTAINER_NAME=steve

# BetterAuth Configuration (for Phase 2 - Portal)
AUTH_SECRET=your_secret_key_here_min_32_chars
AUTH_URL=http://localhost:8000
